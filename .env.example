# =============================================================================
# PokéProgress — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# Generate secrets with: docker compose exec backend bin/rails secret
# =============================================================================

# --- Rails ---
RAILS_ENV=development

# Generate with: bin/rails secret (run once per environment)
SECRET_KEY_BASE=replace_with_output_of_rails_secret

# Contents of config/master.key — used to decrypt Rails credentials
# Do not share or commit this value
RAILS_MASTER_KEY=replace_with_master_key

# Set to 1 in production to serve assets and enable production logging
RAILS_SERVE_STATIC_FILES=0
RAILS_LOG_TO_STDOUT=1

# --- PostgreSQL ---
POSTGRES_USER=pokeprogress
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=pokeprogress_development
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- CORS ---
# Origin that Rails will accept requests from (your Vite dev server)
FRONTEND_URL=http://localhost:5173

# --- React / Vite ---
# Must be prefixed VITE_ to be accessible in browser-side code
# Points to the Rails API
VITE_API_URL=http://localhost:3000
