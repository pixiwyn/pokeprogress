# =============================================================================
# PokéProgress — .gitignore
# =============================================================================

# --- Secrets ---
.env
backend/config/master.key
backend/config/credentials/*.key

# --- Rails ---
backend/log/*
backend/tmp/*
backend/storage/*
backend/.bundle
backend/public/assets
backend/public/packs
backend/node_modules/

# Rails keeps these dirs but not their contents
!backend/log/.keep
!backend/tmp/.keep
!backend/storage/.keep

# --- React / Vite ---
frontend/dist/
frontend/node_modules/
frontend/.vite/

# --- Docker ---
docker-compose.override.yml

# --- OS noise ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Coverage / test artifacts ---
backend/coverage/
backend/spec/reports/